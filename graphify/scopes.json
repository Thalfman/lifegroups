{
  "stageRoot": ".graphify/stage",
  "outputRoot": "graphify-out",
  "durableOutputs": [
    "graph.json",
    "graph.html",
    "GRAPH_REPORT.md",
    "GRAPH_TREE.html"
  ],
  "cleanGraph": {
    "targetMinNodes": 80,
    "targetMaxNodes": 200,
    "preserveTopFiles": 120,
    "minimumPreserveTopFiles": 60,
    "softenedEdgeWeight": 0.35
  },
  "baseBoundaryFiles": [
    "lib/auth/session.ts",
    "lib/admin/run-action.ts",
    "lib/leader/run-action.ts",
    "lib/shared/run-action.ts",
    "lib/shared/action-result.ts",
    "lib/shared/rpc.ts",
    "lib/supabase/server.ts",
    "lib/supabase/read-core.ts",
    "lib/supabase/read-batch.ts",
    "lib/utils.ts",
    "types/enums.ts"
  ],
  "baseExclude": [
    {
      "label": "docs",
      "prefixes": ["docs/", ".github/"],
      "suffixes": [".md", ".mdx", ".png", ".svg"]
    },
    {
      "label": "tests",
      "contains": ["/__tests__/"],
      "regex": ["(^|/)tests/", "\\.(test|spec)\\.[cm]?[tj]sx?$"]
    },
    {
      "label": "a11y harness",
      "prefixes": ["app/a11y-harness/"]
    },
    {
      "label": "Graphify tooling/output",
      "prefixes": [".graphify/", "graphify-out/", "graphify/"],
      "files": [".graphify-version", ".graphifyignore"]
    },
    {
      "label": "package and lock metadata",
      "files": [
        "package.json",
        "package-lock.json",
        "skills-lock.json",
        "components.json",
        ".lintstagedrc",
        ".prettierrc",
        ".prettierignore",
        "eslint.config.mjs",
        "next.config.ts",
        "postcss.config.mjs",
        "playwright.config.ts",
        "tailwind.config.ts",
        "tsconfig.json",
        "tsconfig.tsbuildinfo"
      ]
    },
    {
      "label": "build output and machine-local artifacts",
      "prefixes": [
        ".next/",
        "node_modules/",
        "out/",
        "dist/",
        "coverage/",
        "test-results/",
        "playwright-report/",
        "blob-report/",
        ".claude/",
        ".agents/",
        ".husky/"
      ],
      "suffixes": [".log", ".tmp"]
    },
    {
      "label": "generic scripts",
      "prefixes": ["scripts/"]
    },
    {
      "label": "secrets and local environment",
      "prefixes": ["supabase/dev/"],
      "regex": ["^\\.env"]
    }
  ],
  "scopes": {
    "product": {
      "title": "Product Surface",
      "output": ".",
      "report": "PRODUCT_SURFACE_REPORT.md",
      "cleanGraph": true,
      "includeBoundarySet": true,
      "include": {
        "files": ["middleware.ts", "app/page.tsx", "app/layout.tsx"],
        "prefixes": [
          "app/(protected)/",
          "app/auth/",
          "app/forgot-password/",
          "app/invite/",
          "app/login/",
          "app/reset-password/",
          "app/unauthorized/",
          "app/welcome/",
          "components/admin/",
          "components/auth/",
          "components/lg/",
          "components/pastoral/",
          "components/sign-in/",
          "components/ui/",
          "lib/account/",
          "lib/admin/",
          "lib/auth/",
          "lib/calendar/",
          "lib/crypto/",
          "lib/dashboard/",
          "lib/forms/",
          "lib/home/",
          "lib/hooks/",
          "lib/leader/",
          "lib/nav/",
          "lib/observability/",
          "lib/over-shepherd/",
          "lib/security/",
          "lib/shared/",
          "lib/supabase/",
          "lib/usage/"
        ],
        "regex": ["^types/enums\\.ts$"]
      },
      "exclude": [
        {
          "label": "data-boundary-only generated types",
          "files": ["types/database.ts", "lib/supabase/types.ts"]
        },
        {
          "label": "data-boundary-only database corpus",
          "prefixes": ["supabase/"]
        }
      ]
    },
    "data-boundary": {
      "title": "Data Boundary",
      "output": "data-boundary",
      "report": "DATA_BOUNDARY_REPORT.md",
      "include": {
        "files": [
          "middleware.ts",
          "types/database.ts",
          "types/enums.ts",
          "lib/supabase/types.ts",
          "lib/shared/rpc.ts",
          "lib/shared/action-result.ts",
          "lib/shared/run-action.ts",
          "lib/admin/run-action.ts",
          "lib/leader/run-action.ts",
          "lib/auth/session.ts",
          "lib/auth/roles.ts",
          "lib/supabase/server.ts"
        ],
        "prefixes": [
          "lib/supabase/",
          "supabase/functions/",
          "supabase/migrations/"
        ],
        "regex": [
          "^app/.*/actions\\.ts$",
          "^app/.*/[a-z0-9-]+-actions\\.ts$",
          "^app/.*/route\\.ts$",
          "^lib/.*/rpc\\.ts$",
          "^lib/.*/.*-reads\\.ts$"
        ]
      },
      "exclude": []
    },
    "plumbing": {
      "title": "Shared Plumbing",
      "output": "shared-plumbing",
      "report": "SHARED_PLUMBING_REPORT.md",
      "include": {
        "files": [
          "middleware.ts",
          "components/admin/forms/action-form.tsx",
          "components/admin/forms/confirm-action-button.tsx",
          "components/admin/forms/field-styles.ts",
          "components/lg/Icon.tsx",
          "lib/admin/run-action.ts",
          "lib/leader/run-action.ts",
          "lib/shared/rpc.ts",
          "lib/shared/action-result.ts",
          "lib/shared/run-action.ts",
          "lib/supabase/server.ts",
          "lib/supabase/middleware.ts",
          "lib/supabase/config.ts",
          "lib/supabase/cached-config.ts",
          "lib/utils.ts",
          "types/enums.ts"
        ],
        "prefixes": [
          "components/auth/",
          "components/pastoral/",
          "components/sign-in/",
          "components/ui/",
          "lib/auth/",
          "lib/forms/",
          "lib/hooks/",
          "lib/observability/",
          "lib/security/",
          "lib/shared/"
        ]
      },
      "exclude": []
    },
    "feature-plan": {
      "title": "Plan Feature",
      "output": "features/plan",
      "report": "PLAN_FEATURE_REPORT.md",
      "includeBoundarySet": true,
      "include": {
        "prefixes": [
          "app/(protected)/admin/plan/",
          "app/(protected)/admin/planning/",
          "app/(protected)/admin/launch-planning/",
          "app/(protected)/admin/leader-pipeline/",
          "components/admin/plan/",
          "components/admin/planning/",
          "components/admin/launch-planning/",
          "components/admin/leader-pipeline/",
          "lib/admin/prospect",
          "lib/admin/launch-planning",
          "lib/admin/leader-pipeline",
          "lib/dashboard/launch-planning",
          "lib/supabase/prospect-reads.ts",
          "lib/supabase/readiness-reads.ts"
        ]
      },
      "exclude": []
    },
    "feature-multiply": {
      "title": "Multiply Feature",
      "output": "features/multiply",
      "report": "MULTIPLY_FEATURE_REPORT.md",
      "includeBoundarySet": true,
      "include": {
        "prefixes": [
          "app/(protected)/admin/multiply/",
          "components/admin/multiply/",
          "components/admin/multiplication/",
          "components/admin/settings/multiply-trigger-editor.tsx",
          "lib/admin/multiplication",
          "lib/admin/multiply",
          "lib/admin/readiness",
          "lib/supabase/multiplication-config-reads.ts",
          "lib/supabase/readiness-reads.ts"
        ]
      },
      "exclude": []
    },
    "feature-care": {
      "title": "Care Feature",
      "output": "features/care",
      "report": "CARE_FEATURE_REPORT.md",
      "includeBoundarySet": true,
      "include": {
        "prefixes": [
          "app/(protected)/admin/care/",
          "app/(protected)/admin/follow-ups/",
          "app/(protected)/admin/shepherd-care/",
          "app/(protected)/leader/",
          "app/(protected)/over-shepherd/",
          "components/admin/care/",
          "components/admin/follow-ups/",
          "components/admin/shepherd-care/",
          "lib/admin/care",
          "lib/admin/shepherd-care",
          "lib/leader/",
          "lib/over-shepherd/",
          "lib/supabase/care",
          "lib/supabase/follow-up-reads.ts",
          "lib/supabase/member-care-reads.ts",
          "lib/supabase/shepherd-care-reads.ts"
        ]
      },
      "exclude": []
    },
    "feature-calendar": {
      "title": "Calendar Feature",
      "output": "features/calendar",
      "report": "CALENDAR_FEATURE_REPORT.md",
      "includeBoundarySet": true,
      "include": {
        "prefixes": [
          "app/(protected)/admin/calendar/",
          "app/(protected)/admin/check-ins/",
          "app/(protected)/admin/groups/",
          "app/(protected)/leader/",
          "components/admin/admin-master-calendar",
          "components/admin/check-in",
          "lib/calendar/",
          "lib/shared/church-time.ts",
          "lib/supabase/read-models.ts"
        ]
      },
      "exclude": []
    },
    "feature-people": {
      "title": "People Feature",
      "output": "features/people",
      "report": "PEOPLE_FEATURE_REPORT.md",
      "includeBoundarySet": true,
      "include": {
        "prefixes": [
          "app/(protected)/admin/people/",
          "app/(protected)/admin/guests/",
          "app/(protected)/admin/super-admin/invite",
          "app/(protected)/admin/super-admin/people",
          "components/admin/people",
          "components/admin/person-detail/",
          "components/admin/guests/",
          "components/admin/forms/assign",
          "components/admin/forms/change-leader-role-form.tsx",
          "components/admin/forms/invite-workflow-form.tsx",
          "components/admin/forms/leader-profile-form.tsx",
          "components/admin/forms/member-form.tsx",
          "components/admin/forms/people-import-form.tsx",
          "components/admin/forms/profile-status-form.tsx",
          "components/admin/forms/role-change-form.tsx",
          "components/admin/people-directory.tsx",
          "lib/account/",
          "lib/admin/validation/invite-link.ts",
          "lib/admin/validation/people",
          "lib/supabase/guests-reads.ts",
          "lib/supabase/prospect-reads.ts",
          "lib/supabase/read-models.ts"
        ]
      },
      "exclude": []
    },
    "feature-groups": {
      "title": "Groups Feature",
      "output": "features/groups",
      "report": "GROUPS_FEATURE_REPORT.md",
      "includeBoundarySet": true,
      "include": {
        "prefixes": [
          "app/(protected)/admin/groups/",
          "app/(protected)/admin/group-health/",
          "components/admin/group-detail/",
          "components/admin/group-health/",
          "components/admin/groups/",
          "components/admin/group-management",
          "components/admin/groups-directory.tsx",
          "lib/admin/group",
          "lib/admin/health-rubric",
          "lib/admin/metrics",
          "lib/dashboard/admin-group-model.ts",
          "lib/dashboard/group",
          "lib/supabase/group",
          "lib/supabase/health-rubric-reads.ts"
        ]
      },
      "exclude": []
    },
    "feature-settings": {
      "title": "Settings Feature",
      "output": "features/settings",
      "report": "SETTINGS_FEATURE_REPORT.md",
      "includeBoundarySet": true,
      "include": {
        "prefixes": [
          "app/(protected)/admin/settings/",
          "app/(protected)/admin/super-admin/platform-config",
          "app/(protected)/admin/super-admin/feature-flag",
          "components/admin/settings/",
          "components/admin/settings-shell.tsx",
          "components/admin/settings-tabs.tsx",
          "lib/admin/app-config",
          "lib/admin/editable-copy",
          "lib/admin/feature-flags",
          "lib/admin/group-categories",
          "lib/admin/health-rubric",
          "lib/admin/multiply-trigger",
          "lib/admin/validation/settings",
          "lib/supabase/cached-config.ts",
          "lib/supabase/config.ts",
          "lib/supabase/group-categories-reads.ts",
          "lib/supabase/health-rubric-reads.ts",
          "lib/supabase/multiplication-config-reads.ts"
        ]
      },
      "exclude": []
    }
  },
  "featureOrder": [
    "feature-plan",
    "feature-multiply",
    "feature-care",
    "feature-calendar",
    "feature-people",
    "feature-groups",
    "feature-settings"
  ]
}
