# Preferred: server-only, evaluated at runtime (not inlined by next build).
# Use these for Docker / build-once-promote-later style deploys.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Compatibility: inlined at build time. Fine for Vercel preview/prod where build
# and runtime share env vars. Phase 3 reads are server-only, but these stay for
# convenience and any future browser-side use.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy fallback. Only read if no publishable key is set. Safe to leave unset.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Test accounts (manual scripts only — see docs/TEST_AUTH_USERS.md).
#
# Never set these in committed production config. The manual seed/remove
# scripts in scripts/ require ENABLE_TEST_AUTH_USERS=true; remote Supabase
# targets additionally require ALLOW_TEST_USERS_ON_REMOTE_SUPABASE=true;
# the remove script requires CONFIRM_REMOVE_TEST_AUTH_USERS=true.
#
# The Edge Function (supabase/functions/manage-test-auth-users) reads its
# own copies of these from `supabase secrets`, not from this file.
#
# SUPABASE_SERVICE_ROLE_KEY is required by the manual scripts only. Never
# add it to the Next app runtime. Do not commit a real value here.
# ---------------------------------------------------------------------------

ENABLE_TEST_AUTH_USERS=false
ALLOW_TEST_USERS_ON_REMOTE_SUPABASE=false
CONFIRM_REMOVE_TEST_AUTH_USERS=false

SUPABASE_SERVICE_ROLE_KEY=

TEST_ADMIN_EMAIL=test.admin@lifegroups.local
TEST_ADMIN_PASSWORD=replace-me

TEST_LEADER1_EMAIL=test.leader1@lifegroups.local
TEST_LEADER1_PASSWORD=replace-me

TEST_LEADER2_EMAIL=test.leader2@lifegroups.local
TEST_LEADER2_PASSWORD=replace-me

TEST_COLEADER_EMAIL=test.coleader@lifegroups.local
TEST_COLEADER_PASSWORD=replace-me

# ---------------------------------------------------------------------------
# Optional: Upstash Redis credentials for the forgot-password rate limiter.
#
# When both are set the action enforces per-IP (5/15min) and per-email
# (3/15min) sliding windows. When either is missing the limiter no-ops and a
# `rate_limit_disabled` warn line is emitted so the gap is visible in logs.
# Safe to leave unset in local development.
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
