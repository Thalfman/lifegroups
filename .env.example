# Preferred: server-only, evaluated at runtime (not inlined by next build).
# Use these for Docker / build-once-promote-later style deploys.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Compatibility: inlined at build time. Fine for Vercel preview/prod where build
# and runtime share env vars. Phase 3 reads are server-only, but these stay for
# convenience and any future browser-side use.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy fallback. Only read if no publishable key is set. Safe to leave unset.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
