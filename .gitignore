# Claude Code agent worktrees (transient, isolated)
.claude/worktrees/

# Graphify knowledge graph: graph, report, and HTML visuals are committed
# (the pre-commit hook refreshes them all); the extraction cache and manifest
# are machine-local (absolute paths / mtimes) and are not. The lockfile must
# stay ignored or pre-commit's "untracked files present" check would skip
# every graph refresh.
/graphify-out/cache/
/graphify-out/manifest.json
/graphify-out/.update.log
/graphify-out/.rebuild.lock
