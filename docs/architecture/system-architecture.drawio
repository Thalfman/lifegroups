        <!-- Supabase / Postgres tier -->
        <mxCell id="supa" value="Supabase  —  Postgres + Auth  (Row Level Security on every operational table)" style="swimlane;startSize=30;html=1;fillColor=#eef6ee;strokeColor=#82b366;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="850" width="1360" height="300" as="geometry" />
