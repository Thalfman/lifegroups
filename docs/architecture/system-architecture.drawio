<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="System-Architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1180" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Heading -->
        <mxCell id="title" value="LifeGroups — System Architecture  (Next.js 16 App Router + Supabase)" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="8" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Read path: RLS-scoped, column-allowlisted reads through the reads seam.  Write path: validate → guard → SECURITY DEFINER RPC → revalidatePath → log, with a paired audit_events row per mutation." style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="80" y="38" width="1100" height="20" as="geometry" />
        </mxCell>

        <!-- Browser tier -->
        <mxCell id="browser" value="Browser  (Client)" style="swimlane;startSize=28;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="380" y="70" width="520" height="110" as="geometry" />
        </mxCell>
        <mxCell id="cshell" value="Client Shell  (React 19, &quot;use client&quot;)&#xa;stateful container — forms &amp; interactions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="150" y="42" width="220" height="55" as="geometry" />
        </mxCell>

        <!-- proxy.ts -->
        <mxCell id="proxy" value="proxy.ts  —  updateSupabaseSession()&#xa;refreshes the auth cookie on every request" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="380" y="220" width="520" height="56" as="geometry" />
        </mxCell>

        <!-- Next.js server tier -->
