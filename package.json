{
  "name": "lifegroups",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "next build && next experimental-analyze --output",
    "start": "next start",
    "verify:toolchain": "node scripts/verify-toolchain.mjs",
    "lint": "npm run verify:toolchain && eslint .",
    "typecheck": "npm run verify:toolchain && tsc --noEmit",
    "test": "vitest",
    "test:run": "npm run verify:toolchain && vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "npm run verify:toolchain && vitest run --coverage",
    "test:a11y": "npm run verify:toolchain && playwright test",
    "test:e2e": "bash scripts/e2e.sh",
    "seed:test-auth": "tsx scripts/seed-test-auth-users.ts",
    "remove:test-auth": "tsx scripts/remove-test-auth-users.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.3",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.106.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "27.0.1",
    "lint-staged": "^17.0.6",
    "pg": "^8.21.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6",
    "ws": "^8.21.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
