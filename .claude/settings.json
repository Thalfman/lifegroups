{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run test:run)",
      "Bash(npm run test:run -- *)",
      "Bash(npm run build)",
      "Bash(npx vitest run *)",
      "Bash(git status)",
      "Bash(git status --short)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)"
    ]
  }
}
