{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "xhigh",
  "alwaysThinkingEnabled": true,
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run build)",
      "Bash(npm run test:run)",
      "Bash(npm run test:run -- *)",
      "Bash(npm run test:integration)",
      "Bash(npm run test:coverage)",
      "Bash(npm run test:a11y)",
      "Bash(npm run verify:toolchain)",
      "Bash(npx vitest run *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx playwright test *)",
      "Bash(npx prettier --check *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git stash list)",
      "Bash(git remote -v)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/node_modules/**)",
      "Read(**/.ssh/**)",
      "Bash(sudo *)",
      "Bash(rm -rf /)"
    ]
  }
}
