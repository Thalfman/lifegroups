#!/bin/sh
npx lint-staged
npm run typecheck
npm run test:run

# Refresh and stage only the default clean Product Surface graph outputs.
(
  npm run graph:product &&
    git add -- \
      graphify-out/graph.json \
      graphify-out/graph.html \
      graphify-out/GRAPH_REPORT.md \
      graphify-out/GRAPH_TREE.html \
      graphify-out/.graphify_labels.json \
      graphify-out/PRODUCT_SURFACE_REPORT.md
) || echo "[pre-commit] graph:product failed; committing without graph refresh"
